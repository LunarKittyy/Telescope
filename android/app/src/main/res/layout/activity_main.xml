<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorHeader"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_marginEnd="12dp"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Telescope"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnSurface"
            android:letterSpacing="0.02" />

        <ImageButton
            android:id="@+id/btnScanQr"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_qr_scan"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Scan QR code to pair with desktop"
            android:padding="10dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <!-- Camera settings card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CAMERA"
                        android:textSize="11sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerCamera"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/spinner_bg"
                        android:popupBackground="@color/colorSurfaceRaised" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESOLUTION"
                        android:textSize="11sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerResolution"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/spinner_bg"
                        android:popupBackground="@color/colorSurfaceRaised" />

                    <CheckBox
                        android:id="@+id/checkOis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Optical Image Stabilization (OIS)"
                        android:textSize="14sp"
                        android:textColor="@color/colorOnSurface"
                        android:buttonTint="@color/colorPrimary"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/checkLocalOnly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Local only - USB (disables Wi-Fi access)"
                        android:textSize="14sp"
                        android:textColor="@color/colorOnSurface"
                        android:buttonTint="@color/colorPrimary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stream button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:text="Start Streaming"
                android:textSize="15sp"
                android:letterSpacing="0.04"
                android:textColor="@color/colorOnPrimary"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="10dp" />

            <!-- Status card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○ Not streaming"
                        android:textSize="13sp"
                        android:textColor="@color/colorOnSurfaceDim"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="0dp" />

                    <!-- Link pills — hidden when not streaming -->
                    <LinearLayout
                        android:id="@+id/layoutLinks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/tvLinkWifi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/pill_link"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurface"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/tvLinkUsb"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/pill_link"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurface"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Camera debug card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DETECTED CAMERAS"
                        android:textSize="11sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvCameraList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="@color/colorOnSurfaceDim" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
